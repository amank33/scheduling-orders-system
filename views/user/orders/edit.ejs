<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Order - Scheduling Orders System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f5f7fa; }
        .navbar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .form-section { background: white; border-radius: 10px; padding: 30px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .error-text { color: #dc3545; font-size: 0.875rem; margin-top: 5px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">📅 Scheduling Orders</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/user/dashboard">Dashboard</a>
                <a class="nav-link" href="/user/orders/list">My Orders</a>
                <a class="nav-link" href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <h2 class="mb-4">Edit Scheduled Order</h2>

        <% if(success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= success_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="form-section">
            <form method="POST" action="/user/orders/update/<%= order._id %>">
                <div class="mb-3">
                    <label for="productName" class="form-label">Product Name</label>
                    <input type="text" class="form-control" id="productName" name="productName" value="<%= order.productName || '' %>">
                    <% if(errors && errors.productName) { %>
                        <div class="error-text"><%= errors.productName %></div>
                    <% } %>
                </div>

                <div class="mb-3">
                    <label for="quantity" class="form-label">Quantity <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" id="quantity" name="quantity" min="1" value="<%= order.quantity %>" required>
                    <% if(errors && errors.quantity) { %>
                        <div class="error-text"><%= errors.quantity %></div>
                    <% } %>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea class="form-control" id="description" name="description" rows="3"><%= order.description || '' %></textarea>
                    <% if(errors && errors.description) { %>
                        <div class="error-text"><%= errors.description %></div>
                    <% } %>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="scheduledTime" class="form-label">Schedule Time <span class="text-danger">*</span></label>
                        <input type="datetime-local" class="form-control" id="scheduledTime" name="scheduledTime" value="<%= order.scheduledTime.toISOString().slice(0, 16) %>" required>
                        <% if(errors && errors.scheduledTime) { %>
                            <div class="error-text"><%= errors.scheduledTime %></div>
                        <% } %>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label for="recurrenceType" class="form-label">Recurrence Type <span class="text-danger">*</span></label>
                        <select class="form-select" id="recurrenceType" name="recurrenceType" required>
                            <option value="once" <%= order.recurrenceType === 'once' ? 'selected' : '' %>>Once</option>
                            <option value="daily" <%= order.recurrenceType === 'daily' ? 'selected' : '' %>>Daily</option>
                            <option value="weekly" <%= order.recurrenceType === 'weekly' ? 'selected' : '' %>>Weekly</option>
                            <option value="monthly" <%= order.recurrenceType === 'monthly' ? 'selected' : '' %>>Monthly</option>
                        </select>
                        <% if(errors && errors.recurrenceType) { %>
                            <div class="error-text"><%= errors.recurrenceType %></div>
                        <% } %>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="notes" class="form-label">Notes (optional)</label>
                    <textarea class="form-control" id="notes" name="notes" rows="2"><%= order.notes || '' %></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Update Order</button>
                    <a href="/user/orders/list" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
