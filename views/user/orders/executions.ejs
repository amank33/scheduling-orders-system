<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Execution History - Scheduling Orders System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f5f7fa; }
        .navbar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .table-card { background: white; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .badge-success { background-color: #d4edda; color: #155724; }
        .badge-failed { background-color: #f8d7da; color: #721c24; }
        .badge-pending { background-color: #fff3cd; color: #856404; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">📅 Scheduling Orders</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/user/dashboard">Dashboard</a>
                <a class="nav-link" href="/user/orders/list">My Orders</a>
                <a class="nav-link" href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <div class="mb-4">
            <a href="/user/orders/list" class="btn btn-outline-secondary">← Back to Orders</a>
            <h2 class="mt-3">Execution History - <%= order.productName %></h2>
            <p class="text-muted">Total Executions: <strong><%= order.totalExecutions %></strong> | Failed: <strong><%= order.failedExecutions %></strong></p>
        </div>

        <div class="table-card">
            <% if(executions && executions.length > 0) { %>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th>Executed At</th>
                                <th>Status</th>
                                <th>Amount</th>
                                <th>Notification</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% executions.forEach(exec => { %>
                                <tr>
                                    <td><code><%= exec.executionDetails.orderId || 'N/A' %></code></td>
                                    <td><%= new Date(exec.executedAt).toLocaleString() %></td>
                                    <td>
                                        <span class="badge <%= exec.status === 'success' ? 'badge-success' : (exec.status === 'failed' ? 'badge-failed' : 'badge-pending') %>">
                                            <%= exec.status.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td>$<%= exec.executionDetails.amount || '0.00' %></td>
                                    <td>
                                        <span class="badge <%= exec.notificationSent ? 'bg-success' : 'bg-warning' %>">
                                            <%= exec.notificationSent ? 'Sent' : 'Pending' %>
                                        </span>
                                    </td>
                                    <td>
                                        <% if(exec.errorMessage) { %>
                                            <small class="text-danger"><%= exec.errorMessage %></small>
                                        <% } else { %>
                                            <small class="text-muted">Items: <%= exec.executionDetails.items %></small>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="p-5 text-center">
                    <p class="text-muted">No execution records yet. This order will appear here once it executes.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
