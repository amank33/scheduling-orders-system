<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Orders - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f5f7fa; }
        .navbar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .table-card { background: white; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .user-card { background: white; border-radius: 10px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 20px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">📅 Scheduling Orders</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/admin/dashboard">Dashboard</a>
                <a class="nav-link" href="/admin/users/list">Users</a>
                <a class="nav-link" href="/admin/orders/list">Orders</a>
                <a class="nav-link" href="/admin/executions/list">Executions</a>
                <a class="nav-link" href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <a href="/admin/users/list" class="btn btn-outline-secondary mb-3">← Back to Users</a>

        <div class="user-card">
            <h3><%= user.username %></h3>
            <p><strong>Email:</strong> <%= user.email %></p>
            <p><strong>Full Name:</strong> <%= user.fullName %></p>
            <p><strong>Phone:</strong> <%= user.phone || 'Not provided' %></p>
            <p><strong>Member Since:</strong> <%= new Date(user.createdAt).toLocaleDateString() %></p>
            <p><strong>Status:</strong> <span class="badge <%= user.isActive ? 'bg-success' : 'bg-danger' %>"><%= user.isActive ? 'Active' : 'Inactive' %></span></p>
        </div>

        <h4>Scheduled Orders (<%= orders.length %>)</h4>
        <div class="table-card mb-4">
            <% if(orders && orders.length > 0) { %>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Schedule</th>
                                <th>Recurrence</th>
                                <th>Status</th>
                                <th>Executions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { %>
                                <tr>
                                    <td><%= order.productName %></td>
                                    <td><%= order.quantity %></td>
                                    <td><%= new Date(order.scheduledTime).toLocaleString() %></td>
                                    <td><span class="badge bg-info"><%= order.recurrenceType %></span></td>
                                    <td><span class="badge <%= order.status === 'active' ? 'bg-success' : 'bg-secondary' %>"><%= order.status %></span></td>
                                    <td><%= order.totalExecutions %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="p-5 text-center">
                    <p class="text-muted">No scheduled orders.</p>
                </div>
            <% } %>
        </div>

        <h4>Execution History (<%= executions.length %>)</h4>
        <div class="table-card">
            <% if(executions && executions.length > 0) { %>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order ID</th>
                                <th>Executed At</th>
                                <th>Status</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% executions.forEach(exec => { %>
                                <tr>
                                    <td><code><%= exec.executionDetails.orderId %></code></td>
                                    <td><%= new Date(exec.executedAt).toLocaleString() %></td>
                                    <td><span class="badge <%= exec.status === 'success' ? 'bg-success' : 'bg-danger' %>"><%= exec.status %></span></td>
                                    <td>$<%= exec.executionDetails.amount %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="p-5 text-center">
                    <p class="text-muted">No execution history.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
