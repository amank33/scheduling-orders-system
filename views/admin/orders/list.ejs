<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Orders - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f5f7fa; }
        .navbar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .table-card { background: white; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">📅 Scheduling Orders</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/admin/dashboard">Dashboard</a>
                <a class="nav-link" href="/admin/users/list">Users</a>
                <a class="nav-link active" href="/admin/orders/list">Orders</a>
                <a class="nav-link" href="/admin/executions/list">Executions</a>
                <a class="nav-link" href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <h2 class="mb-4">All Scheduled Orders</h2>

        <div class="table-card">
            <% if(orders && orders.length > 0) { %>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Schedule</th>
                                <th>Recurrence</th>
                                <th>Status</th>
                                <th>Total Executions</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { %>
                                <tr>
                                    <td><%= order.userId.username %></td>
                                    <td><%= order.productName %></td>
                                    <td><%= order.quantity %></td>
                                    <td><%= new Date(order.scheduledTime).toLocaleString() %></td>
                                    <td><span class="badge bg-info"><%= order.recurrenceType %></span></td>
                                    <td><span class="badge bg-<%= order.status === 'active' ? 'success' : (order.status === 'paused' ? 'warning' : 'secondary') %>"><%= order.status %></span></td>
                                    <td><%= order.totalExecutions %></td>
                                    <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="p-5 text-center">
                    <p class="text-muted">No orders yet.</p>
                </div>
            <% } %>
        </div>
        
        <div class="mt-4">
            <a href="/admin/dashboard" class="btn btn-outline-secondary">← Back to Dashboard</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
