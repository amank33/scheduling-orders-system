<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scheduling Orders System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #fff;
            color: #222;
        }
        .navbar {
            background: #2c3e50;
            border-bottom: 1px solid #ddd;
        }
        .navbar-brand {
            color: white !important;
            font-weight: normal;
            font-size: 1.2rem;
        }
        .navbar-nav .nav-link {
            color: #bbb !important;
            font-size: 14px;
        }
        .navbar-nav .nav-link:hover {
            color: white !important;
        }
        .hero {
            text-align: center;
            color: #222;
            padding: 80px 20px;
            background: #f5f5f5;
        }
        .hero h1 {
            font-size: 2.5rem;
            font-weight: normal;
            margin-bottom: 15px;
        }
        .hero p {
            font-size: 1rem;
            margin-bottom: 30px;
            color: #666;
        }
        .btn-hero {
            padding: 10px 25px;
            font-size: 14px;
            font-weight: normal;
            border-radius: 0;
            transition: none;
            margin: 5px;
        }
        .btn-hero-primary {
            background-color: #2c3e50;
            border: 1px solid #2c3e50;
            color: white;
        }
        .btn-hero-primary:hover {
            background-color: #34495e;
            border-color: #34495e;
        }
        .btn-hero-secondary {
            background-color: transparent;
            color: #2c3e50;
            border: 1px solid #2c3e50;
        }
        .btn-hero-secondary:hover {
            background-color: #2c3e50;
            color: white;
        }
        .features {
            padding: 60px 20px;
        }
        .feature {
            background: #fafafa;
            padding: 30px;
            border: 1px solid #e0e0e0;
            text-align: center;
            margin-bottom: 20px;
        }
        .feature-icon {
            font-size: 2rem;
            margin-bottom: 15px;
        }
        .feature h5 {
            font-weight: normal;
            font-size: 1.1rem;
            margin-bottom: 10px;
        }
        .feature p {
            font-size: 14px;
            color: #666;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Scheduling Orders System</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link" href="/auth/register">Register</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="hero">
        <h1>Order Scheduling System</h1>
        <p>Create and manage scheduled orders with automatic execution</p>
        <a href="/auth/login" class="btn btn-hero btn-hero-primary">Login</a>
        <a href="/auth/register" class="btn btn-hero btn-hero-secondary">Register</a>
    </div>

    <div class="container features">
        <div class="row">
            <div class="col-md-4">
                <div class="feature">
                    <div class="feature-icon">📋</div>
                    <h5>Schedule Orders</h5>
                    <p>Create and manage orders with custom scheduling options</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature">
                    <div class="feature-icon">🔄</div>
                    <h5>Auto Execute</h5>
                    <p>Orders are automatically executed at the scheduled time</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature">
                    <div class="feature-icon">📧</div>
                    <h5>Notifications</h5>
                    <p>Receive email updates on order execution status</p>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
